# --- Public-facing proxy --------------------------------------------------
# Hostname the proxy will serve. Use a real hostname for cert issuance, or
# "localhost" for local development (Caddy will use its internal CA).
MCP_PUBLIC_HOST=localhost
# Bearer token clients must present. Generate a long random value.
MCP_BEARER_TOKEN=change-me-to-a-long-random-string

# --- MCP service ----------------------------------------------------------
# Port the mcp service listens on (internal to compose network).
MCP_INTERNAL_PORT=8080
# Idle timeout (seconds) before a session's R child is torn down. Sessions
# with active jobs are NOT reaped regardless of idleness.
MCP_SESSION_IDLE_TIMEOUT=3600
# Hard cap on concurrent sessions (= concurrent Rserve children).
MCP_MAX_SESSIONS=16
# Per-session and global caps on concurrent mcparallel jobs.
MCP_MAX_JOBS_PER_SESSION=2
MCP_MAX_JOBS_GLOBAL=8
# Logging
MCP_LOG_LEVEL=INFO
# DNS-rebinding protection (added in MCP SDK 1.27). Off by default because
# we already enforce Host validation at the Caddy layer plus a bearer
# token, and the mcp service is not directly reachable from outside the
# compose network. To re-enable, set the flag and provide allowlists:
#   MCP_ENABLE_DNS_REBINDING_PROTECTION=true
#   MCP_ALLOWED_HOSTS=mcp:8080,localhost
#   MCP_ALLOWED_ORIGINS=https://your.public.host
MCP_ENABLE_DNS_REBINDING_PROTECTION=false
MCP_ALLOWED_HOSTS=
MCP_ALLOWED_ORIGINS=

# --- Rserve ---------------------------------------------------------------
# Internal hostname (compose service name) and port.
RSERVE_HOST=rserve
RSERVE_PORT=6311

# --- Build-time only ------------------------------------------------------
# Pinned package refs the rserve image installs from GitHub.
MICROBIOMEDB_REF=v1.1.2
# microbiomeData is pinned to a specific commit rather than v1.0.7
# because v1.0.7 still references veupathUtils, which has since been
# replaced by mbioUtils. There's no release tag for the migrated state
# yet; bump this once one exists.
MICROBIOMEDATA_REF=ced9da6f012842596ffa411b473e2781f296f384
# Set to "false" to build a slimmer image without the curated-data
# package. Curated-dataset MCP tools are then automatically hidden.
INSTALL_MICROBIOMEDATA=true
# Optional GitHub PAT for `remotes::install_github`. Without one, large
# tarball downloads frequently time out under the unauthenticated rate
# limit. Use a fine-grained token with public_repo read access.
GITHUB_PAT=
